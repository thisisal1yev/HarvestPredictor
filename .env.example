# Database
POSTGRES_USER=harvest
POSTGRES_PASSWORD=change-me-strong-random-32
POSTGRES_DB=harvestpredictor
DATABASE_URL="postgresql://harvest:change-me-strong-random-32@localhost:5432/harvestpredictor"

# Public URL — must equal nginx server_name AND MINIO_SERVER_URL
PUBLIC_URL=https://app.harvestpredictor.example

# Nuxt auth
NUXT_SESSION_PASSWORD=your-generated-secret-key

# MinIO — root credentials (init script + MinIO server only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-random-32

# MinIO — service account (used by Nuxt + Python at runtime, scoped to detections/*)
# Constraints: access key 3-20 chars, secret key 8-40 chars (MinIO svcacct limit)
# Generate: openssl rand -hex 8  (16 chars) and openssl rand -hex 20 (40 chars)
MINIO_ACCESS_KEY=svcacct-access-key
MINIO_SECRET_KEY=svcacct-secret-key
MINIO_BUCKET=harvest-snapshots
MINIO_PUBLIC_ENDPOINT=https://app.harvestpredictor.example
MINIO_PRESIGNED_TTL=3600

# CV Service <-> Nuxt
CV_SERVICE_URL=http://localhost:8100
CV_API_KEY=your-cv-api-key-here

# Encryption master key — INJECTED ONLY INTO cv-service container, NEVER into Nuxt
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=base64:CHANGE_ME_32_BYTES_BASE64

# Stream limits
MAX_CONCURRENT_STREAMS=5
STREAM_THROTTLE_SECONDS=0.5
STREAM_DEDUP_WINDOW_SECONDS=60
